# ============================================================
#  EGroupware OpenAPI Tool Server — Environment Configuration
# ============================================================

# Base URL of your EGroupware installation (no trailing slash)
EGW_BASE_URL=https://your-egroupware.example.org/egroupware

# --- Authentication (choose ONE of the two methods below) ---

# Method 1: Application Token (recommended — create in EGroupware under
#           Admin > API Tokens or user preferences > API Tokens)
EGW_TOKEN=your-application-token-here

# Method 2: Username + Password (Basic Auth)
# EGW_USERNAME=your_username
# EGW_PASSWORD=your_password

# ============================================================
# If both TOKEN and USERNAME/PASSWORD are set, TOKEN takes priority.
# ============================================================
